# App
APP_MODULE=app.main:app
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Cache / Refresh
DATABASE_PATH=data/stockinfo.db
CACHE_TTL_HOURS=6
REFRESH_INTERVAL_HOURS=6
METADATA_TTL_DAYS=7

# ISIN-Auflösung
DEFAULT_EXCHANGE=XETR
OPENFIGI_API_KEY=

# Profil-Links (Platzhalter {isin} bzw. {symbol})
EXTRAETF_ETF_URL=https://extraetf.com/de/etf-profile/{isin}
EXTRAETF_STOCK_URL=https://extraetf.com/de/stock-profile/{isin}
YAHOO_URL=https://de.finance.yahoo.com/quote/{symbol}/

# Makefile-Theme (classic|ocean|earth|night|mono|sunset|forest|neon|shell)
MAKE_THEME=classic
